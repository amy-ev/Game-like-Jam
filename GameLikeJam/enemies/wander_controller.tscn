[sub_resource type="GDScript" id="GDScript_lu0vb"]
script/source = "extends Node3D

var start_pos = null
var target_pos = null

@onready var timer = $Timer

func _on_timer_timeout():
	update_target()

func update_target():
	var target_vector = Vector3(randi_range(-8,8), 0.0,randi_range(-8,8)) # change to Vector3
	target_pos = start_pos + target_vector

func get_time_left():
	return timer.time_left
	
func start_timer(duration):
	timer.start(duration)
"

