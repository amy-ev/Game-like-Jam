[sub_resource type="GDScript" id="GDScript_ndybt"]
script/source = "extends CanvasLayer

@onready var raccoon_vision = $raccoon_vision

func _ready() -> void:
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	var root = get_tree().get_root()
	if root.has_node(\"/root/transition\"):
		print(\"got it\")
		var anim = root.get_node(\"/root/transition\")
		root.remove_child(anim)
	raccoon_vision.visible = false


func _on_button_pressed() -> void:
	Global.new_game()
	get_tree().change_scene_to_file(\"res://animation.tscn\")


func _on_raccoon_vision_toggled(toggled_on: bool) -> void:
	print(toggled_on)
	if toggled_on == true:
		raccoon_vision.visible = true
		Global.raccoon_vision = true
	else:
		raccoon_vision.visible = false
		Global.raccoon_vision = false
"

