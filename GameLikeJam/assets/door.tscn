[sub_resource type="GDScript" id="GDScript_ytpji"]
resource_name = "door"
script/source = "extends Area3D

var detected := false
var opened := false
var direction:= \"\"
var animation:= \"\"

var animation_dict = {
	\"front\": \"door-open-1\",
	\"back\": \"door-open-2\"
}

func _on_body_entered(body: Node3D) -> void:
	if body.is_in_group(\"player\"):
		detected = true
		direction = get_direction(body)

func _input(event: InputEvent) -> void:
	if detected and !opened:
		if event.is_action_pressed(\"interact\"):
			animation = animation_dict.get(direction,\"RESET\")
			get_node(\"AnimationPlayer\").play(animation)
			opened = true


func _on_body_exited(body: Node3D) -> void:
	if body.is_in_group(\"player\"):
		detected = false
		if opened:
			get_node(\"AnimationPlayer\").play_backwards(animation)
			opened = false

func get_direction(body: Node3D) -> String:
	var entrance = body.global_position - self.global_position
	var forward = -self.global_transform.basis.z
	
	var dot_product = entrance.normalized().dot(forward.normalized())
	
	if dot_product > 0:
		return \"front\"
	else:
		return \"back\"
	
"

